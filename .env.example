# ===========================================================================
# Copie ce fichier en ".env" et adapte les valeurs. Le .env n'est PAS versionné.
# ===========================================================================

# --- Données à ingérer ---------------------------------------------------
# Liste des mois à télécharger (format AAAA-MM séparés par des virgules).
# DEV / démo rapide : 1 ou 2 mois suffisent (déjà ~3M lignes par mois).
# Rapport final (>1M garanti, partitionnement démontré) : mets plusieurs mois.
TLC_MONTHS=2024-01

# --- Stockage ------------------------------------------------------------
# En LOCAL : laisse DATA_ROOT pointer sur un dossier local (gratuit).
# Les couches seront créées sous ce dossier : bronze/ silver/ gold/
DATA_ROOT=./data

# Sur AWS, les scripts utilisent plutôt ces variables (remplies par Terraform) :
# DATA_LAKE_BUCKET=mon-bucket-unique-pipeline-taxi
# AWS_REGION=eu-west-3

# --- Pseudonymisation RGPD ----------------------------------------------
# Sel secret utilisé pour hacher l'identifiant chauffeur (NE PAS publier en vrai).
PSEUDO_SALT=change-me-please

# --- Échantillonnage ML (pour que l'entraînement reste rapide/gratuit) ---
ML_SAMPLE_ROWS=200000

# --- Alerting (OPTIONNEL) : email d'alerte en cas d'échec de la pipeline -----
# Si tu crées un topic SNS dans la console AWS (avec un abonnement email confirmé),
# colle son ARN ici : l'orchestrateur enverra un email automatiquement en cas d'échec.
# Laisse vide si tu ne veux pas d'email (l'alerte reste affichée en console).
# ALERT_SNS_TOPIC_ARN=arn:aws:sns:eu-west-3:123456789012:nyc-taxi-alerts
